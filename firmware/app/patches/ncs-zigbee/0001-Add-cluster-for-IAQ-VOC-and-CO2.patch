diff --git a/lib/zboss/include/zcl/zb_zcl_co2_cluster.h b/lib/zboss/include/zcl/zb_zcl_co2_cluster.h
new file mode 100644
index 0000000..d2d5054
--- /dev/null
+++ b/lib/zboss/include/zcl/zb_zcl_co2_cluster.h
@@ -0,0 +1,108 @@
+#ifndef ZB_ZCL_CO2_MEASUREMENT_H_
+#define ZB_ZCL_CO2_MEASUREMENT_H_
+
+#include <zcl/zb_zcl_common.h>
+#include <zcl/zb_zcl_commands.h>
+
+enum zb_zcl_co2_cluster_attr_e
+{
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_VALUE_ID        = 0x0000,
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_ID    = 0x0001,
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_ID    = 0x0002,
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_TOLERANCE_ID    = 0x0003,
+};
+
+/** @brief Default value for CO2 Measurement cluster revision global attribute */
+#define ZB_ZCL_CO2_MEASUREMENT_CLUSTER_REVISION_DEFAULT             ((zb_uint16_t)0x0001U)
+
+/** @brief MeasuredValue attribute unknown value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_VALUE_UNKNOWN                   ((zb_uint16_t)0x8000)
+
+/** @brief MinMeasuredValue attribute minimum value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_MIN_VALUE             ((zb_uint16_t)0x0000)
+
+/** @brief MinMeasuredValue attribute maximum value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_MAX_VALUE             ((zb_uint16_t)0x0190)
+
+/** @brief MinMeasuredValue attribute invalid value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_INVALID               ((zb_uint16_t)0x8000)
+
+/** @brief MaxMeasuredValue attribute minimum value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_MIN_VALUE             ((zb_uint16_t)0x0000)
+
+/** @brief MaxMeasuredValue attribute maximum value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_MAX_VALUE             ((zb_uint16_t)0x0190)
+
+/** @brief MaxMeasuredValue attribute invalid value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_INVALID               ((zb_uint16_t)0x8000)
+
+/** @brief Tolerance attribute minimum value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_TOLERANCE_MIN_VALUE             ((zb_uint16_t)0x0000)
+
+/** @brief Tolerance attribute maximum value */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_TOLERANCE_MAX_VALUE             ((zb_uint16_t)0x000F)
+
+/** @brief Default value for Value attribute */
+#define ZB_ZCL_ATTR_CO2_MEASUREMENT_VALUE_DEFAULT_VALUE             ((zb_uint16_t)0x0000)
+
+#define ZB_SET_ATTR_DESCR_WITH_ZB_ZCL_ATTR_CO2_MEASUREMENT_VALUE_ID(data_ptr)           \
+{                                                                                       \
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_VALUE_ID,                                               \
+    ZB_ZCL_ATTR_TYPE_U16,                                                               \
+    ZB_ZCL_ATTR_ACCESS_READ_ONLY | ZB_ZCL_ATTR_ACCESS_REPORTING,                        \
+    (ZB_ZCL_NON_MANUFACTURER_SPECIFIC),                                                 \
+    (void*) data_ptr                                                                    \
+}
+
+#define ZB_SET_ATTR_DESCR_WITH_ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_ID(data_ptr)       \
+{                                                                                       \
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_ID,                                           \
+    ZB_ZCL_ATTR_TYPE_U16,                                                               \
+    ZB_ZCL_ATTR_ACCESS_READ_ONLY,                                                       \
+    (ZB_ZCL_NON_MANUFACTURER_SPECIFIC),                                                 \
+    (void*) data_ptr                                                                    \
+}
+
+#define ZB_SET_ATTR_DESCR_WITH_ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_ID(data_ptr)       \
+{                                                                                       \
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_ID,                                           \
+    ZB_ZCL_ATTR_TYPE_U16,                                                               \
+    ZB_ZCL_ATTR_ACCESS_READ_ONLY,                                                       \
+    (ZB_ZCL_NON_MANUFACTURER_SPECIFIC),                                                 \
+    (void*) data_ptr                                                                    \
+}
+
+#define ZB_SET_ATTR_DESCR_WITH_ZB_ZCL_ATTR_CO2_MEASUREMENT_TOLERANCE_ID(data_ptr)       \
+{                                                                                       \
+    ZB_ZCL_ATTR_CO2_MEASUREMENT_TOLERANCE_ID,                                           \
+    ZB_ZCL_ATTR_TYPE_U8,                                                                \
+    ZB_ZCL_ATTR_ACCESS_READ_ONLY,                                                       \
+    (ZB_ZCL_NON_MANUFACTURER_SPECIFIC),                                                 \
+    (void*) data_ptr                                                                    \
+}
+
+/** @brief Number of attributes mandatory for reporting in CO2 Measurement cluster */
+#define ZB_ZCL_CO2_MEASUREMENT_REPORT_ATTR_COUNT 1
+
+/** @brief Declare attribute list for CO2 Measurement cluster - server side
+    @param attr_list - attribute list name
+    @param value - pointer to variable to store MeasuredValue attribute
+    @param min_value - pointer to variable to store MinMeasuredValue attribute
+    @param max_value - pointer to variable to store MAxMeasuredValue attribute
+    @param tolerance - pointer to variable to store Tolerance attribute
+*/
+#define ZB_ZCL_DECLARE_CO2_MEASUREMENT_ATTRIB_LIST(attr_list, value, min_value, max_value, tolerance)       \
+    ZB_ZCL_START_DECLARE_ATTRIB_LIST_CLUSTER_REVISION(attr_list, ZB_ZCL_CO2_MEASUREMENT)                    \
+    ZB_ZCL_SET_ATTR_DESC(ZB_ZCL_ATTR_CO2_MEASUREMENT_VALUE_ID, (value))                                     \
+    ZB_ZCL_SET_ATTR_DESC(ZB_ZCL_ATTR_CO2_MEASUREMENT_MIN_VALUE_ID, (min_value))                             \
+    ZB_ZCL_SET_ATTR_DESC(ZB_ZCL_ATTR_CO2_MEASUREMENT_MAX_VALUE_ID, (max_value))                             \
+    ZB_ZCL_SET_ATTR_DESC(ZB_ZCL_ATTR_CO2_MEASUREMENT_TOLERANCE_ID, (tolerance))                             \
+    ZB_ZCL_FINISH_DECLARE_ATTRIB_LIST
+
+void zb_zcl_co2_measurement_init_server(void);
+void zb_zcl_co2_measurement_init_client(void);
+
+#define ZB_ZCL_CLUSTER_ID_CO2_MEASUREMENT_SERVER_ROLE_INIT zb_zcl_co2_measurement_init_server
+#define ZB_ZCL_CLUSTER_ID_CO2_MEASUREMENT_CLIENT_ROLE_INIT zb_zcl_co2_measurement_init_client
+
+#endif /* ZB_ZCL_CO2_MEASUREMENT_H_ */
\ No newline at end of file
